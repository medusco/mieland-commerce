{
  "name": "@mieland/commerce-api",
  "version": "0.1.0",
  "private": true,
  "description": "Lean Express + GraphQL Yoga commerce API (WooGraphQL-compatible subset)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke": "tsx src/compatibility/smoke.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@graphql-tools/schema": "^10.0.23",
    "@graphql-yoga/plugin-disable-introspection": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dataloader": "^2.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "google-auth-library": "^9.15.1",
    "graphql": "^16.10.0",
    "graphql-depth-limit": "^1.1.0",
    "graphql-yoga": "^5.12.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.6.0",
    "jose": "^5.10.0",
    "mysql2": "^3.14.0",
    "rate-limit-redis": "^4.2.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "wordpress-hash-node": "^1.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/graphql-depth-limit": "^1.1.6",
    "@types/node": "^22.13.10",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
