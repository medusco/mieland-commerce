PORT=4000
NODE_ENV=development

# MySQL (shared WooCommerce DB)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=wordpress
MYSQL_PASSWORD=wordpress
MYSQL_DATABASE=wordpress
MYSQL_TABLE_PREFIX=hy_
MYSQL_POOL_SIZE=10

# Redis (carts + APQ + rate limits)
REDIS_URL=redis://127.0.0.1:6379
CART_TTL_SECONDS=604800
APQ_TTL_SECONDS=2592000

# WordPress / WooCommerce REST (needed for checkout / placeOrder)
WORDPRESS_URL=http://localhost:8000
# Public media/CDN base (same as WP S3_UPLOADS_BUCKET_URL). Alias: S3_UPLOADS_BUCKET_URL
MEDIA_BASE_URL=https://img.mieland.com
# Consumer key/secret from WP: WooCommerce → Settings → Advanced → REST API
consumerKey=
consumerSecret=
# Aliases (same values): WC_CONSUMER_KEY / WC_CONSUMER_SECRET / CONSUMER_KEY / CONSUMER_SECRET
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=
WC_REST_TIMEOUT_MS=15000
# processOrderPayment → Store API checkout (Stripe); default 60s
WC_STORE_PAYMENT_TIMEOUT_MS=60000

# CORS — comma-separated shop origins
CORS_ORIGIN=http://localhost:3000

# Optional overrides (prefer MySQL wpgraphql_login_* options in production)
JWT_SECRET=
GRAPHQL_SECRET=
MAX_BODY_BYTES=1048576
GRAPHQL_MAX_DEPTH=12
GRAPHQL_MAX_COMPLEXITY=500

# Catalog cache TTL (seconds)
CATALOG_CACHE_TTL_SECONDS=60

# Smoke (npm run smoke)
# SMOKE_USERNAME=
# SMOKE_PASSWORD=
# SMOKE_PRODUCT_ID=
# SMOKE_SUBSCRIPTION_PRODUCT_ID=
# SMOKE_SUBSCRIPTION_FREQUENCY=monthly
# SMOKE_OOS_PRODUCT_ID=
# SMOKE_OVERSTOCK_QTY=9
# SMOKE_SKIP_CHECKOUT=0
# Local default: http://127.0.0.1:4000/graphql
# Remote (any one of):
# SMOKE_BASE_URL=https://your-commerce-api.up.railway.app
# GRAPHQL_URL=https://your-commerce-api.up.railway.app/graphql
# npm run smoke -- --url https://your-commerce-api.up.railway.app
